APP_NAME=genai-gateway
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
CHAT_PROVIDER=openai
MODEL_ROUTING_RULES_JSON={"legal_qa.cheap":{"provider":"openrouter","model":"openai/gpt-4.1-mini"},"legal_qa.default":{"provider":"openrouter","model":"openai/gpt-4.1-mini"},"legal_qa.high_quality":{"provider":"openrouter","model":"openai/gpt-4.1"}}
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=
OPENROUTER_TITLE=genai-gateway
EMBEDDING_PROVIDER=deterministic
EMBEDDING_MODEL=text-embedding-3-small
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/genai_gateway
PROMPT_ROOT=apps/legal_doc_qa/backend/prompts
DEFAULT_TASK=legal_qa
DEFAULT_PROMPT_VERSION=v1
RETRIEVAL_TOP_K=4
